# AI Agent服务配置
APP_NAME=AI Agent Service
VERSION=1.0.0
HOST=0.0.0.0
PORT=8889
DEBUG=True
LOG_LEVEL=INFO

# AI配置
AI_PROVIDER=openai
AI_MODEL=gpt-4
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# Anthropic配置
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MySQL配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=hot_ai

# 缓存配置
CACHE_TTL=3600

# Rate Limit配置
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# 向量数据库配置
VECTOR_STORE_PATH=./vector_store
VECTOR_STORE_TYPE=chroma
